rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User profiles
    match /users/{userId} {
      function isValidUser(data) {
        return data.username is string && data.username.size() >= 3 && data.username.size() <= 32
          && (data.avatar == null || (data.avatar is string && data.avatar.size() <= 512));
      }

      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['username', 'avatar', 'totalPoints', 'gamesPlayed', 'lastActive']);
    }

    // Game rooms
    match /rooms/{roomId} {
      function isValidRoom(data) {
        return data.status in ['waiting', 'playing', 'finished']
          && data.players is list && data.players.size() <= 10;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidRoom(request.resource.data) && isValidId(roomId);
      allow update: if isSignedIn() && isValidRoom(request.resource.data)
        // Allow joining, starting, finishing, and scoring
        && (
          // Action: Join
          (resource.data.status == 'waiting' && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players'])) ||
          // Action: Start/Finish
          (request.resource.data.diff(resource.data).affectedKeys().hasAll(['status'])) ||
          // Action: Update Score
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['scores', 'currentQuestionIndex']))
        );

      // Questions subcollection
      match /questions/{questionId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
      }
    }

    // Sesiones de juego — historial completo para analytics
    match /sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.auth.uid == request.resource.data.uid ||
        request.auth.token.email == 'haroldorellana20@gmail.com'
      );
    }

    // Leaderboard — una entrada por jugador (su mejor puntaje)
    match /leaderboard/{entryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.uid;
      allow update: if isSignedIn() && request.auth.uid == resource.data.uid
        && request.auth.uid == request.resource.data.uid;
    }
  }
}
